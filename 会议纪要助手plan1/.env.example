# GEMINI_API_KEY: Required for /api/gemini-summary (Gemini 1.5 Flash via @google/genai SDK).
# Copy this file to .env and fill in your real key from https://aistudio.google.com/apikey
DASHSCOPE_API_KEY=your_dashscope_api_key_here"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
